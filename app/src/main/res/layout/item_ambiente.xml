<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="15dp"
    app:cardElevation="5dp"
    app:strokeWidth="1dp"
    android:layout_marginBottom="15dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:layout_marginRight="18dp"
            android:id="@+id/imgAmbienteTipo"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/txtAmbienteNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laboratotio de cómputo"
                android:textStyle="bold"
                android:textSize="14dp"/>
            <TextView
                android:id="@+id/txtCodigoAmbiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COD_AMBIENTE"
                android:textStyle="bold"
                android:textSize="14dp"/>
            <TextView
                android:id="@+id/txtTipoAmbiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de ambiente"
                android:textStyle="bold"
                android:textSize="14dp"/>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>